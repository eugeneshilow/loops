# loops — your OWN Telegram userbot credentials. Lives only on your machine.
# Copy to .loops/.env (git-ignored) — the setup skill does this for you.

# api_id + api_hash from https://my.telegram.org -> "API development tools"
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# The session string is written by `npm run login` (QR login) into
# .loops/personal.session — never paste it here, never commit it.

# Speech-to-text backend for voice notes: mlx-whisper (Apple) | openai
STT_BACKEND=mlx-whisper
# mlx model id (whisper-small-mlx downloads reliably; large-v3-turbo often does not)
STT_MODEL=mlx-community/whisper-small-mlx
STT_LANGUAGE=ru
# path to the mlx_whisper binary (Apple Silicon venv)
MLX_WHISPER_BIN=~/.stt-venv/bin/mlx_whisper
# for STT_BACKEND=openai instead of mlx:
OPENAI_API_KEY=

# tg-contacts-feedback: comma-separated tester @handles the loop is allowed to read/reply
LOOP_TESTERS=
